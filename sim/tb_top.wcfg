<?xml version="1.0" encoding="UTF-8"?>
<wave_config>
   <wave_state>
   </wave_state>
   <db_ref_list>
      <db_ref path="tb_top.wdb" id="1" type="auto">
         <top_modules>
            <top_module name="tb_top" />
         </top_modules>
      </db_ref>
   </db_ref_list>
   <zoom_setting>
      <ZoomStartTime time="0fs"/>
      <ZoomEndTime time="200us"/>
      <Cursor1Time time="0fs"/>
   </zoom_setting>
   <column_width_setting>
      <NameColumnWidth column_width="220"/>
      <ValueColumnWidth column_width="80"/>
   </column_width_setting>
   <WVObjectSize size="20" />

   <wvobject fp_name="/tb_top/dut/u_ctrl/state" type="enum">
      <obj_property name="ElementShortName">ps</obj_property>
      <obj_property name="ObjectShortName">ps</obj_property>
   </wvobject>

